# ─── E2E Test Environment ──────────────────────────────────────────────────────
# Copy this file to .env.e2e and fill in the values.
# Used by Playwright locally via: dotenv -e .env.e2e -- playwright test
# In CI, these are set directly as environment variables in the workflow.

# ─── Contentful ────────────────────────────────────────────────────────────────
# Required — home page fetches Contentful at request time, so the dev server
# Playwright boots needs these to render anything. Same values as .env.local.
CONTENTFUL_SPACE=
CONTENTFUL_TOKEN=
