# ─── E2E Test Environment ──────────────────────────────────────────────────────
# Copy this file to .env.e2e and fill in the values.
# This file is used by Playwright locally via: dotenv -e .env.e2e -- playwright test
# In CI, these are set directly as environment variables in e2e.yml.

# Enables the test credentials provider in NextAuth (bypasses Azure AD for E2E)
E2E_TEST=true

# Password used by all test users — must match the value stored in your local Supabase auth
# Set this to any strong password and ensure it matches your seed data
E2E_TEST_SECRET=

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ─── Supabase (local) ──────────────────────────────────────────────────────────
# These point at the local Supabase stack started by: npm run supabase:start
# The service role key is printed by `npx supabase start` or `npx supabase status`
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# ─── Contentful ────────────────────────────────────────────────────────────────
# Required to start the dev server (home page fetches Contentful at runtime)
# Use your real Contentful credentials — same as .env.local
CONTENTFUL_SPACE=
CONTENTFUL_TOKEN=

# ─── Azure AD (dummy values) ───────────────────────────────────────────────────
# Not called during E2E tests — credentials provider is used instead
AZURE_AD_CLIENT_ID=ci-placeholder
AZURE_AD_CLIENT_SECRET=ci-placeholder
AZURE_AD_TENANT_ID=ci-placeholder
