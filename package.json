{
  "name": "hshb",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "prepare": "husky || true",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pipeline:check": "npm run lint && npm run format:check && npm run type-check && npm run test:coverage && npm run build",
    "fix:all": "npm run lint:fix && npm run format && npm run type-check"
  },
  "browserslist": "defaults, not ie <= 11",
  "dependencies": {
    "@headlessui/react": "2.2.9",
    "@heroicons/react": "2.2.0",
    "@next/third-parties": "16.1.7",
    "@supabase/supabase-js": "2.99.2",
    "babel-plugin-react-compiler": "1.0.0",
    "clsx": "2.1.1",
    "contentful": "11.10.6",
    "next": "16.1.7",
    "next-auth": "5.0.0-beta.30",
    "next-mdx-remote": "6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "server-only": "0.0.1",
    "web-push": "3.6.7"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "9.39.4",
    "@netlify/plugin-nextjs": "5.15.9",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/postcss": "4.2.1",
    "@tailwindcss/typography": "0.5.19",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "3.6.4",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.0",
    "autoprefixer": "10.4.27",
    "eslint": "9.39.4",
    "eslint-config-next": "16.1.7",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "husky": "9.1.7",
    "jsdom": "29.0.0",
    "lint-staged": "16.4.0",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "sharp": "0.34.5",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "8.0.0",
    "vitest": "4.1.0"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.1",
    "lightningcss-linux-x64-gnu": "^1.31.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "engines": {
    "npm": ">=11.9.0",
    "node": ">=24.14.0"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
