# ─── Contentful (CMS) ────────────────────────────────────────────────────────
# From your Contentful space → Settings → API keys
CONTENTFUL_SPACE=
CONTENTFUL_TOKEN=

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=

# ─── Microsoft Entra ID (Azure AD) ───────────────────────────────────────────
# From your Azure App Registration → Overview
AZURE_AD_CLIENT_ID=
AZURE_AD_TENANT_ID=

# From your Azure App Registration → Certificates & secrets → Client secrets
AZURE_AD_CLIENT_SECRET=

# ─── Supabase ─────────────────────────────────────────────────────────────────
# From your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
