# ─── Google Analytics ─────────────────────────────────────────────────────────
# From your GA4 property → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_ID=

# ─── Contentful (CMS) ────────────────────────────────────────────────────────
# From your Contentful space → Settings → API keys
CONTENTFUL_SPACE=
CONTENTFUL_TOKEN=

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=

# ─── Microsoft Entra ID (Azure AD) ───────────────────────────────────────────
# From your Azure App Registration → Overview
AZURE_AD_CLIENT_ID=
AZURE_AD_TENANT_ID=

# From your Azure App Registration → Certificates & secrets → Client secrets
AZURE_AD_CLIENT_SECRET=

# ─── Supabase ─────────────────────────────────────────────────────────────────
# From your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Web Push / VAPID ─────────────────────────────────────────────────────────
# Used to send push notifications to admin/headteacher devices when attendance is saved.
# Generate a key pair once with: npx web-push generate-vapid-keys
#
# NEXT_PUBLIC_VAPID_PUBLIC_KEY — safe to expose in the browser (used in pushManager.subscribe)
# VAPID_PRIVATE_KEY            — SECRET, never commit or expose this value
# VAPID_SUBJECT                — contact email included in push requests (e.g. mailto:you@example.com)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
