# ─── Google Analytics ─────────────────────────────────────────────────────────
# From your GA4 property → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_ID=

# ─── Contentful (CMS) ────────────────────────────────────────────────────────
# From your Contentful space → Settings → API keys
CONTENTFUL_SPACE=
CONTENTFUL_TOKEN=

# Only needed locally to regenerate src/types/contentful via `npm run gen:types`.
# This is a CMA personal access token, not a CDA delivery token — generate at:
# https://app.contentful.com/account/profile/cma_tokens
# CI never needs this because the generated types are committed.
CONTENTFUL_MANAGEMENT_TOKEN=
